<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Triplens</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#F8F5F0;--ink:#1A1714;--ink2:#6B6460;--ink3:#B0AAA4;
  --gold:#A8884A;--gold-soft:rgba(168,136,74,0.10);--gold-border:rgba(168,136,74,0.30);
  --white:#FFFFFF;--border:rgba(26,23,20,0.08);--card-border:rgba(26,23,20,0.10);
  --green:#2D6A4F;--green-soft:rgba(45,106,79,0.08);--radius:14px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--ink);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;flex-direction:column;}

/* HEADER */
.header{padding:1.25rem 2rem;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:var(--white);flex-shrink:0;}
.logo{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:var(--ink);}
.logo em{font-style:italic;color:var(--gold);}
.header-right{display:flex;align-items:center;gap:12px;}
.header-dest{font-size:13px;color:var(--ink2);}
.header-dest strong{color:var(--ink);}

/* PROGRESS */
.progress-bar{height:2px;background:var(--border);flex-shrink:0;}
.progress-fill{height:100%;background:var(--gold);transition:width 0.4s ease;}

/* STEP NAV */
.step-nav{display:flex;background:var(--white);border-bottom:1px solid var(--border);padding:0 2rem;flex-shrink:0;overflow-x:auto;}
.step-nav::-webkit-scrollbar{height:0;}
.step-label{font-size:12px;padding:12px 16px;color:var(--ink3);border-bottom:2px solid transparent;white-space:nowrap;letter-spacing:0.02em;transition:all 0.2s;}
.step-label.active{color:var(--ink);border-bottom-color:var(--gold);}
.step-label.done{color:var(--green);}

/* MAIN */
.main{flex:1;padding:2rem;max-width:680px;margin:0 auto;width:100%;}
.page{display:none;animation:fadeUp 0.35s ease forwards;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px);}to{opacity:1;transform:translateY(0);}}

/* TYPOGRAPHY */
.eyebrow{font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;}
.page-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,4vw,38px);font-weight:400;line-height:1.2;margin-bottom:8px;}
.page-sub{font-size:14px;color:var(--ink2);line-height:1.7;margin-bottom:28px;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;font-size:14px;font-family:'DM Sans',sans-serif;font-weight:500;padding:13px 24px;border-radius:10px;border:none;cursor:pointer;transition:all 0.18s;}
.btn-primary{background:var(--ink);color:var(--bg);}
.btn-primary:hover{background:#000;transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,23,20,0.2);}
.btn-primary:disabled{opacity:0.35;cursor:not-allowed;transform:none;box-shadow:none;}
.btn-ghost{background:transparent;color:var(--ink2);border:1px solid var(--card-border);}
.btn-ghost:hover{border-color:var(--ink3);color:var(--ink);}
.btn-gold{background:var(--gold);color:var(--white);}
.btn-gold:hover{background:#8a6e35;transform:translateY(-1px);}
.nav-row{display:flex;align-items:center;justify-content:space-between;margin-top:28px;}
.back-btn{font-size:13px;color:var(--ink3);background:none;border:none;cursor:pointer;font-family:'DM Sans',sans-serif;padding:0;transition:color 0.15s;display:flex;align-items:center;gap:5px;}
.back-btn:hover{color:var(--ink);}

/* ── PAGE 0: WELCOME ── */
.welcome-title{font-family:'Cormorant Garamond',serif;font-size:clamp(34px,6vw,52px);font-weight:300;line-height:1.1;margin-bottom:16px;}
.welcome-title em{font-style:italic;color:var(--gold);}
.welcome-tags{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:28px;}
.welcome-tag{font-size:12px;padding:5px 12px;border-radius:20px;border:1px solid var(--card-border);color:var(--ink2);background:var(--white);}
.dest-label{font-size:12px;letter-spacing:0.05em;text-transform:uppercase;color:var(--ink3);margin-bottom:8px;display:block;}
.dest-input{width:100%;font-size:20px;font-family:'Cormorant Garamond',serif;padding:14px 0;border:none;border-bottom:2px solid var(--ink);background:transparent;color:var(--ink);outline:none;transition:border-color 0.2s;}
.dest-input::placeholder{color:var(--ink3);font-style:italic;}
.dest-input:focus{border-bottom-color:var(--gold);}

/* ── PAGE 1: DICAS ── */
.input-methods{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:20px;}
.method-btn{padding:14px 10px;border-radius:var(--radius);border:1.5px solid var(--card-border);background:var(--white);cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;transition:all 0.18s;font-family:'DM Sans',sans-serif;}
.method-btn:hover{border-color:var(--ink3);transform:translateY(-1px);}
.method-btn.active{border-color:var(--ink);background:var(--ink);color:var(--white);}
.method-icon{font-size:22px;}
.method-label{font-size:12px;font-weight:500;}
.method-desc{font-size:11px;color:var(--ink3);text-align:center;}
.method-btn.active .method-desc{color:rgba(248,245,240,0.5);}
.input-panel{display:none;}
.input-panel.active{display:block;}
.tips-textarea{width:100%;min-height:180px;font-size:14px;font-family:'DM Sans',sans-serif;padding:16px;border:1.5px solid var(--card-border);border-radius:var(--radius);background:var(--white);color:var(--ink);outline:none;resize:vertical;line-height:1.7;transition:border-color 0.2s;}
.tips-textarea:focus{border-color:var(--gold);}
.tips-textarea::placeholder{color:var(--ink3);font-style:italic;}
.extract-box{background:var(--gold-soft);border:1px solid var(--gold-border);border-radius:var(--radius);padding:14px 16px;margin-top:14px;display:none;}
.extract-box.visible{display:block;}
.extract-title{font-size:12px;font-weight:500;color:var(--gold);margin-bottom:8px;}
.extract-items{display:flex;flex-wrap:wrap;gap:6px;}
.extract-item{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:var(--white);border:1px solid var(--gold-border);border-radius:20px;font-size:12px;color:var(--ink);cursor:pointer;transition:all 0.15s;}
.extract-item:hover{background:var(--gold);color:var(--white);border-color:var(--gold);}
.extract-item.added{background:var(--green-soft);border-color:var(--green);color:var(--green);cursor:default;}
.upload-zone{border:2px dashed var(--card-border);border-radius:var(--radius);padding:40px 20px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--white);}
.upload-zone:hover,.upload-zone.drag{border-color:var(--gold);background:var(--gold-soft);}
.upload-input{display:none;}
.uploaded-previews{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px;}
.preview-wrap{position:relative;}
.preview-thumb{width:70px;height:70px;border-radius:8px;object-fit:cover;border:1px solid var(--border);}
.preview-remove{position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:var(--ink);color:var(--white);font-size:10px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;}
.link-row{display:flex;gap:8px;margin-bottom:10px;}
.link-input{flex:1;font-size:13px;font-family:'DM Sans',sans-serif;padding:11px 14px;border:1.5px solid var(--card-border);border-radius:10px;background:var(--white);color:var(--ink);outline:none;transition:border-color 0.2s;}
.link-input:focus{border-color:var(--gold);}
.link-input::placeholder{color:var(--ink3);}
.add-link-btn{padding:11px 16px;border-radius:10px;border:1.5px solid var(--card-border);background:transparent;cursor:pointer;font-size:12px;color:var(--ink2);font-family:'DM Sans',sans-serif;transition:all 0.15s;white-space:nowrap;}
.add-link-btn:hover{border-color:var(--ink);color:var(--ink);}
.link-item{display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:var(--white);border:1px solid var(--border);border-radius:8px;font-size:12px;color:var(--ink2);gap:8px;margin-bottom:6px;}
.link-item span{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.link-remove{background:none;border:none;color:var(--ink3);cursor:pointer;font-size:14px;}
.tips-added{margin-top:20px;}
.tips-added-label{font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.tips-count{background:var(--green-soft);color:var(--green);font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;}
.tip-chip{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;margin:0 5px 6px 0;background:var(--white);border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--ink2);}
.tip-chip-remove{color:var(--ink3);font-size:11px;cursor:pointer;background:none;border:none;padding:0;}

/* ── PAGE 2: FONTES ── */
.sources-list{display:flex;flex-direction:column;gap:12px;margin-bottom:16px;}
.source-card{background:var(--white);border:1px solid var(--card-border);border-radius:var(--radius);overflow:hidden;}
.source-header{padding:16px 18px;display:flex;align-items:center;gap:14px;cursor:pointer;}
.source-avatar{width:40px;height:40px;border-radius:50%;background:var(--ink);color:var(--bg);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:18px;font-weight:400;flex-shrink:0;}
.source-info{flex:1;}
.source-name-input{font-size:15px;font-weight:500;color:var(--ink);border:none;background:transparent;outline:none;font-family:'DM Sans',sans-serif;width:100%;}
.source-name-input::placeholder{color:var(--ink3);font-weight:400;}
.source-tips-count{font-size:11px;color:var(--ink3);margin-top:2px;}
.source-expand{color:var(--ink3);font-size:14px;transition:transform 0.2s;flex-shrink:0;}
.source-expand.open{transform:rotate(180deg);}
.source-body{padding:0 18px 18px;display:none;border-top:1px solid var(--border);}
.source-body.open{display:block;padding-top:16px;}
.source-body-title{font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink3);margin-bottom:12px;}
.trust-options{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;}
.trust-opt{display:flex;align-items:flex-start;gap:10px;padding:10px 12px;border-radius:10px;border:1px solid var(--border);cursor:pointer;background:var(--bg);transition:all 0.15s;}
.trust-opt:hover{border-color:var(--ink3);}
.trust-opt.selected{border-color:var(--ink);background:var(--ink);color:var(--white);}
.trust-opt-emoji{font-size:16px;flex-shrink:0;}
.trust-opt-label{font-size:13px;font-weight:500;margin-bottom:1px;}
.trust-opt-desc{font-size:11px;color:var(--ink2);line-height:1.4;}
.trust-opt.selected .trust-opt-desc{color:rgba(248,245,240,0.55);}
.specialty-label{font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink3);margin:14px 0 8px;}
.specialty-pills{display:flex;flex-wrap:wrap;gap:6px;}
.spec-pill{padding:5px 12px;border-radius:20px;border:1px solid var(--card-border);background:var(--white);font-size:12px;color:var(--ink2);cursor:pointer;transition:all 0.15s;}
.spec-pill:hover{border-color:var(--ink3);}
.spec-pill.selected{background:var(--gold-soft);border-color:var(--gold);color:var(--gold);}
.free-text-toggle{font-size:12px;color:var(--gold);cursor:pointer;background:none;border:none;font-family:'DM Sans',sans-serif;padding:0;margin-top:12px;display:block;text-decoration:underline;text-underline-offset:3px;}
.free-text-area{display:none;margin-top:10px;width:100%;min-height:70px;font-size:13px;font-family:'DM Sans',sans-serif;padding:10px 12px;border:1px solid var(--card-border);border-radius:10px;background:var(--bg);color:var(--ink);outline:none;resize:vertical;line-height:1.6;transition:border-color 0.2s;}
.free-text-area.visible{display:block;}
.free-text-area:focus{border-color:var(--gold);}
.free-text-area::placeholder{color:var(--ink3);}
.add-source-btn{display:flex;align-items:center;gap:8px;padding:13px 18px;border-radius:var(--radius);border:1.5px dashed var(--card-border);background:transparent;cursor:pointer;width:100%;font-size:13px;color:var(--ink2);font-family:'DM Sans',sans-serif;transition:all 0.18s;}
.add-source-btn:hover{border-color:var(--gold);color:var(--gold);}

/* ── PAGES 3-8: ONBOARDING ── */
.step-dots{display:flex;gap:6px;margin-bottom:20px;}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--border);transition:all 0.3s;}
.sdot.done{background:var(--gold);}
.sdot.active{background:var(--ink);width:20px;border-radius:3px;}
.options{display:flex;flex-direction:column;gap:10px;}
.options.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.option{padding:14px 18px;border-radius:var(--radius);border:1px solid var(--card-border);background:var(--white);cursor:pointer;transition:all 0.18s;display:flex;align-items:flex-start;gap:12px;}
.option:hover{border-color:var(--ink3);transform:translateY(-1px);}
.option.selected{background:var(--ink);border-color:var(--ink);color:var(--white);transform:translateY(-1px);box-shadow:0 6px 24px rgba(26,23,20,0.15);}
.opt-emoji{font-size:20px;flex-shrink:0;line-height:1.3;}
.opt-label{font-size:14px;font-weight:500;margin-bottom:2px;line-height:1.3;}
.opt-desc{font-size:12px;color:var(--ink2);line-height:1.5;}
.option.selected .opt-desc{color:rgba(248,245,240,0.6);}
.multi-hint{font-size:11px;color:var(--ink3);margin-bottom:12px;}

/* ── RESULT ── */
.result-card{background:var(--white);border:1px solid var(--card-border);border-radius:20px;padding:28px 32px;margin-bottom:16px;}
.result-dest{font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.result-title{font-family:'Cormorant Garamond',serif;font-size:32px;font-weight:400;margin-bottom:4px;}
.result-sub{font-size:13px;color:var(--ink2);margin-bottom:24px;}
.profile-tags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;}
.profile-tag{font-size:12px;padding:5px 12px;border-radius:20px;background:var(--gold-soft);border:1px solid var(--gold-border);color:var(--gold);}
.rules-title{font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--ink3);margin-bottom:12px;}
.rules-list{list-style:none;display:flex;flex-direction:column;gap:8px;}
.rules-list li{display:flex;align-items:flex-start;gap:10px;font-size:13px;color:var(--ink2);line-height:1.5;}
.rule-icon{color:var(--gold);font-size:14px;flex-shrink:0;margin-top:1px;}
.result-actions{display:flex;gap:10px;flex-wrap:wrap;}

@media(max-width:600px){
  .header{padding:1rem 1.25rem;}
  .main{padding:1.5rem 1.25rem 5rem;}
  .input-methods{grid-template-columns:1fr 1fr;}
  .options.grid2{grid-template-columns:1fr;}
  .result-card{padding:20px;}
}
</style>
</head>
<body>

<header class="header">
  <div class="logo">trip<em>lens</em></div>
  <div class="header-right">
    <span class="header-dest" id="header-dest"></span>
  </div>
</header>
<div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
<nav class="step-nav">
  <div class="step-label" id="snav-0">Destino</div>
  <div class="step-label" id="snav-1">1 · Dicas</div>
  <div class="step-label" id="snav-2">2 · Fontes</div>
  <div class="step-label" id="snav-3">3 · Perfil</div>
  <div class="step-label" id="snav-4">4 · Mapa</div>
</nav>

<main class="main">

<!-- PAGE 0: WELCOME -->
<div class="page active" id="page-0">
  <div class="eyebrow">Bem-vinda ao Triplens</div>
  <h1 class="welcome-title">Suas dicas de viagem,<br><em>organizadas</em> para você.</h1>
  <p class="page-sub">Cole recomendações dos seus amigos, faça upload de prints e receba um mapa personalizado com taste fit calculado.</p>
  <div class="welcome-tags">
    <span class="welcome-tag">🗺 Mapa interativo</span>
    <span class="welcome-tag">⭐ Taste fit</span>
    <span class="welcome-tag">🧭 Itinerário por dia</span>
  </div>
  <label class="dest-label">Para onde você vai?</label>
  <input class="dest-input" id="dest-input" type="text" placeholder="ex: Grécia, Tokyo, Lisboa..." oninput="onDestInput(this.value)" />
  <div class="nav-row" style="margin-top:28px">
    <span></span>
    <button class="btn btn-primary" id="btn-start" onclick="goTo(1)" disabled>Começar →</button>
  </div>
</div>

<!-- PAGE 1: DICAS -->
<div class="page" id="page-1">
  <div class="eyebrow">Passo 1 de 3</div>
  <h1 class="page-title">Adicione suas dicas</h1>
  <p class="page-sub">Cole textos, faça upload de prints ou adicione links. Pode misturar tudo.</p>
  <div class="input-methods">
    <button class="method-btn active" id="meth-text" onclick="setMethod('text')"><span class="method-icon">✏️</span><span class="method-label">Texto</span><span class="method-desc">Cole aqui</span></button>
    <button class="method-btn" id="meth-upload" onclick="setMethod('upload')"><span class="method-icon">📸</span><span class="method-label">Fotos</span><span class="method-desc">Prints</span></button>
    <button class="method-btn" id="meth-link" onclick="setMethod('link')"><span class="method-icon">🔗</span><span class="method-label">Links</span><span class="method-desc">Instagram etc</span></button>
  </div>
  <!-- TEXT -->
  <div class="input-panel active" id="panel-text">
    <textarea class="tips-textarea" id="tips-text" oninput="analyzeText(this.value)"
      placeholder="Cole aqui qualquer coisa — WhatsApp, diário de viagem, notas do iPhone...&#10;&#10;Ex: 'A Fernanda foi em setembro e adorou o restaurante Selene em Santorini.'"></textarea>
    <div class="extract-box" id="extract-box">
      <div class="extract-title">✦ Lugares identificados — clique para adicionar</div>
      <div class="extract-items" id="extract-items"></div>
    </div>
    <div style="display:flex;justify-content:flex-end;margin-top:10px">
      <button class="btn btn-ghost" style="font-size:13px;padding:9px 16px" onclick="addTextBlock()">Adicionar →</button>
    </div>
  </div>
  <!-- UPLOAD -->
  <div class="input-panel" id="panel-upload">
    <div class="upload-zone" onclick="document.getElementById('file-input').click()" ondragover="event.preventDefault();this.classList.add('drag')" ondragleave="this.classList.remove('drag')" ondrop="handleDrop(event)">
      <div style="font-size:36px;margin-bottom:12px">📷</div>
      <div style="font-size:15px;font-weight:500;margin-bottom:4px">Arraste fotos ou clique</div>
      <div style="font-size:12px;color:var(--ink3)">Prints de Instagram, WhatsApp, iPhone</div>
    </div>
    <input type="file" id="file-input" class="upload-input" multiple accept="image/*" onchange="handleFiles(this.files)">
    <div class="uploaded-previews" id="uploaded-previews"></div>
    <div style="display:flex;justify-content:flex-end;margin-top:12px">
      <button class="btn btn-ghost" style="font-size:13px;padding:9px 16px" id="btn-process-photos" onclick="processPhotos()" disabled>Processar fotos →</button>
    </div>
  </div>
  <!-- LINKS -->
  <div class="input-panel" id="panel-link">
    <div class="link-row">
      <input class="link-input" id="link-input" type="url" placeholder="https://www.instagram.com/p/..." />
      <button class="add-link-btn" onclick="addLink()">+ Adicionar</button>
    </div>
    <div id="links-list"></div>
    <div style="display:flex;justify-content:flex-end;margin-top:4px">
      <button class="btn btn-ghost" style="font-size:13px;padding:9px 16px" id="btn-process-links" onclick="processLinks()" disabled>Processar links →</button>
    </div>
  </div>
  <!-- ADDED TIPS -->
  <div class="tips-added" id="tips-added" style="display:none">
    <div class="tips-added-label">Dicas adicionadas <span class="tips-count" id="tips-count">0</span></div>
    <div id="tips-chips"></div>
  </div>
  <div class="nav-row">
    <button class="back-btn" onclick="goTo(0)">← Voltar</button>
    <button class="btn btn-primary" id="btn-next1" onclick="goToSources()" disabled>Continuar → Fontes</button>
  </div>
</div>

<!-- PAGE 2: FONTES -->
<div class="page" id="page-2">
  <div class="eyebrow">Passo 2 de 3</div>
  <h1 class="page-title">Quem deu essas dicas?</h1>
  <p class="page-sub">Calibra o quanto cada recomendação encaixa com você. 1 minuto por pessoa.</p>
  <div class="sources-list" id="sources-list"></div>
  <button class="add-source-btn" onclick="addSource('')"><span style="font-size:18px">+</span> Adicionar outra fonte</button>
  <div class="nav-row">
    <button class="back-btn" onclick="goTo(1)">← Voltar</button>
    <button class="btn btn-primary" onclick="goTo(3)">Continuar → Perfil</button>
  </div>
</div>

<!-- PAGES 3-8: ONBOARDING QUESTIONS -->
<div class="page" id="page-3">
  <div class="step-dots" id="sdots"></div>
  <div class="eyebrow" id="q-eyebrow">Perfil 1 de 6</div>
  <h2 class="page-title" id="q-title"></h2>
  <p class="page-sub" id="q-sub"></p>
  <div class="multi-hint" id="q-hint" style="display:none"></div>
  <div id="q-options"></div>
  <div class="nav-row">
    <button class="back-btn" id="q-back" onclick="qBack()">← Voltar</button>
    <button class="btn btn-primary" id="q-next" onclick="qNext()" disabled>Próxima →</button>
  </div>
</div>

<!-- PAGE 9: RESULT -->
<div class="page" id="page-9">
  <div class="result-card">
    <div class="result-dest" id="res-dest"></div>
    <div class="result-title" id="res-title"></div>
    <div class="result-sub" id="res-sub"></div>
    <div class="profile-tags" id="res-tags"></div>
    <div class="rules-title">Suas regras de decisão</div>
    <ul class="rules-list" id="res-rules"></ul>
  </div>
  <div class="result-actions">
    <button class="btn btn-gold" onclick="alert('Em breve: o mapa da sua viagem! 🗺')">Ver meu mapa →</button>
    <button class="btn btn-ghost" onclick="goTo(3)">Refazer perfil</button>
  </div>
</div>

</main>

<script>
// ── STATE ─────────────────────────────────────────────────────────────────────
let destination = '';
let tips = [];
let sources = [];
let uploadedFiles = [];
let links = [];
let answers = {};
let currentQ = 0;

// ── NAVIGATION ────────────────────────────────────────────────────────────────
function goTo(n) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + n).classList.add('active');
  updateNav(n);
  window.scrollTo({top:0,behavior:'smooth'});
}

function updateNav(n) {
  const pct = [0,20,40,60,80,100];
  document.getElementById('progress-fill').style.width = (pct[Math.min(n,5)] || 90) + '%';
  const stepMap = {0:0, 1:1, 2:2, 3:3, 9:4};
  const active = stepMap[n] !== undefined ? stepMap[n] : 3;
  ['snav-0','snav-1','snav-2','snav-3','snav-4'].forEach((id,i) => {
    const el = document.getElementById(id);
    el.className = 'step-label' + (i < active ? ' done' : i === active ? ' active' : '');
  });
  const dest = document.getElementById('header-dest');
  dest.innerHTML = destination ? '📍 <strong>' + destination + '</strong>' : '';
}

// ── PAGE 0 ────────────────────────────────────────────────────────────────────
function onDestInput(v) {
  destination = v.trim();
  document.getElementById('btn-start').disabled = destination.length < 2;
}

// ── PAGE 1: DICAS ─────────────────────────────────────────────────────────────
function setMethod(m) {
  ['text','upload','link'].forEach(x => {
    document.getElementById('meth-' + x).classList.toggle('active', x === m);
    document.getElementById('panel-' + x).classList.toggle('active', x === m);
  });
}

const PLACE_RE = [
  /restaurante\s+([A-Z][a-záéíóúãõâêôçàü\s]+)/gi,
  /(?:fui|foi|fomos|recomend\w+|adorei|adorou|amei|amou)\s+(?:n[oa]?\s+)?([A-Z][a-zA-Záéíóúãõâêôç\s&'-]{3,30})/gi,
];
let extractTimer;
function analyzeText(val) {
  clearTimeout(extractTimer);
  if (val.length < 20) { document.getElementById('extract-box').classList.remove('visible'); return; }
  extractTimer = setTimeout(() => {
    const found = new Set();
    PLACE_RE.forEach(re => { re.lastIndex=0; let m; while((m=re.exec(val))!==null){ const n=m[1].trim().replace(/\s+/,' '); if(n.length>3&&n.length<40) found.add(n); } });
    if (found.size > 0) {
      document.getElementById('extract-box').classList.add('visible');
      document.getElementById('extract-items').innerHTML = Array.from(found).slice(0,8).map(name => {
        const added = tips.some(t => t.name === name);
        return '<div class="extract-item' + (added?' added':'') + '" onclick="' + (added?'':('addExtract(this,\'' + name.replace(/'/g,"\\'") + '\')')) + '">' + (added?'✓ ':'+') + ' ' + name + '</div>';
      }).join('');
    }
  }, 600);
}

function addExtract(el, name) {
  if (el.classList.contains('added')) return;
  tips.push({name, raw:name, cat:'place'});
  el.classList.add('added'); el.innerHTML = '✓ ' + name;
  refreshTips();
}

function addTextBlock() {
  const val = document.getElementById('tips-text').value.trim();
  if (!val) return;
  tips.push({name:'Texto colado', raw:val, cat:'text-block', isBlock:true});
  document.getElementById('tips-text').value = '';
  document.getElementById('extract-box').classList.remove('visible');
  refreshTips();
}

function handleFiles(files) {
  Array.from(files).forEach(file => {
    if (!file.type.startsWith('image/')) return;
    uploadedFiles.push(file);
    const reader = new FileReader();
    reader.onload = e => {
      const wrap = document.createElement('div');
      wrap.className = 'preview-wrap';
      wrap.id = 'prev-' + file.name.replace(/\W/g,'_');
      wrap.innerHTML = '<img class="preview-thumb" src="' + e.target.result + '"><button class="preview-remove" onclick="removePhoto(\'' + file.name + '\')">✕</button>';
      document.getElementById('uploaded-previews').appendChild(wrap);
    };
    reader.readAsDataURL(file);
    document.getElementById('btn-process-photos').disabled = false;
  });
}
function handleDrop(e) { e.preventDefault(); document.querySelector('.upload-zone').classList.remove('drag'); handleFiles(e.dataTransfer.files); }
function removePhoto(name) {
  uploadedFiles = uploadedFiles.filter(f => f.name !== name);
  const el = document.getElementById('prev-' + name.replace(/\W/g,'_'));
  if (el) el.remove();
  document.getElementById('btn-process-photos').disabled = uploadedFiles.length === 0;
}
function processPhotos() {
  uploadedFiles.forEach(f => tips.push({name:f.name, raw:'[Imagem: '+f.name+']', cat:'photo', isPhoto:true}));
  uploadedFiles = [];
  document.getElementById('uploaded-previews').innerHTML = '';
  document.getElementById('btn-process-photos').disabled = true;
  refreshTips();
}
function addLink() {
  const input = document.getElementById('link-input');
  const val = input.value.trim(); if (!val) return;
  links.push(val); input.value = '';
  renderLinks();
  document.getElementById('btn-process-links').disabled = false;
}
function renderLinks() {
  document.getElementById('links-list').innerHTML = links.map((l,i) =>
    '<div class="link-item"><span>' + l + '</span><button class="link-remove" onclick="removeLink(' + i + ')">✕</button></div>'
  ).join('');
}
function removeLink(i) { links.splice(i,1); renderLinks(); document.getElementById('btn-process-links').disabled = links.length===0; }
function processLinks() {
  links.forEach(l => tips.push({name:'Link', raw:l, cat:'link', isLink:true}));
  links = []; renderLinks();
  document.getElementById('btn-process-links').disabled = true;
  refreshTips();
}
function removeTip(i) { tips.splice(i,1); refreshTips(); }
function refreshTips() {
  const section = document.getElementById('tips-added');
  const chips = document.getElementById('tips-chips');
  const count = document.getElementById('tips-count');
  document.getElementById('btn-next1').disabled = tips.length === 0;
  if (tips.length === 0) { section.style.display = 'none'; return; }
  section.style.display = 'block';
  count.textContent = tips.length;
  chips.innerHTML = tips.map((t,i) => {
    const icon = t.isPhoto ? '📸' : t.isLink ? '🔗' : t.isBlock ? '📝' : '📍';
    const label = t.isBlock ? 'Texto colado' : t.name;
    return '<div class="tip-chip">' + icon + ' ' + (label.length>28?label.slice(0,26)+'…':label) + ' <button class="tip-chip-remove" onclick="removeTip(' + i + ')">✕</button></div>';
  }).join('');
}

// ── PAGE 2: FONTES ────────────────────────────────────────────────────────────
const TRUST_OPTS = [
  {val:'same', emoji:'🪞', label:'Mesmo gosto que eu', desc:'Mesma vibe — confio muito'},
  {val:'expert', emoji:'🎓', label:'Expert no destino', desc:'Conhece bem o lugar, foi várias vezes'},
  {val:'similar', emoji:'✨', label:'Gosto parecido', desc:'Algumas coisas batem, outras não'},
  {val:'different', emoji:'🌀', label:'Gosto diferente', desc:'Não sei se encaixa com o meu perfil'},
  {val:'custom', emoji:'✍️', label:'Prefiro descrever', desc:'Vou escrever minha própria definição'},
];
const SPECS = ['🍽 Restaurantes','🍸 Bares','☕ Cafés','🏛 Cultura','🛍 Compras','⛩ Atividades'];

function goToSources() {
  if (sources.length === 0) {
    // Auto-detect names from text blocks
    const names = new Set();
    tips.forEach(t => {
      if (t.isBlock) {
        const m = t.raw.match(/\b(?:a |o )?([A-Z][a-záéíóúãõ]+)\s+(?:foi|recomendou|falou|disse|adorou|amou)/g);
        if (m) m.forEach(x => { const n = x.replace(/^(a |o )/i,'').split(/\s+/)[0]; if(n.length>2) names.add(n); });
      }
    });
    names.forEach(n => addSource(n));
    if (sources.length === 0) addSource('');
  }
  renderSources();
  goTo(2);
}

function addSource(name) {
  sources.push({id:'s'+Date.now()+Math.floor(Math.random()*9999), name:name||'', trust:null, specialties:[], freeText:''});
  renderSources();
}

function renderSources() {
  document.getElementById('sources-list').innerHTML = sources.map((s,idx) => {
    const init = s.name ? s.name[0].toUpperCase() : '?';
    return '<div class="source-card" id="sc-' + s.id + '">' +
      '<div class="source-header" onclick="toggleSource(\'' + s.id + '\')">' +
        '<div class="source-avatar">' + init + '</div>' +
        '<div class="source-info">' +
          '<input class="source-name-input" placeholder="Nome da pessoa" value="' + s.name + '" oninput="updateSrcName(\'' + s.id + '\',this.value)" onclick="event.stopPropagation()" />' +
          '<div class="source-tips-count">' + (s.trust ? TRUST_OPTS.find(o=>o.val===s.trust)?.label : 'Clique para classificar') + '</div>' +
        '</div>' +
        '<span class="source-expand" id="exp-' + s.id + '">▾</span>' +
      '</div>' +
      '<div class="source-body" id="sb-' + s.id + '">' +
        '<div class="source-body-title">Como você classificaria o gosto dela?</div>' +
        '<div class="trust-options">' +
          TRUST_OPTS.map(o => '<div class="trust-opt' + (s.trust===o.val?' selected':'') + '" onclick="setTrust(\'' + s.id + '\',\'' + o.val + '\')">' +
            '<span class="trust-opt-emoji">' + o.emoji + '</span>' +
            '<div><div class="trust-opt-label">' + o.label + '</div><div class="trust-opt-desc">' + o.desc + '</div></div>' +
          '</div>').join('') +
        '</div>' +
        '<div class="specialty-label">Melhor para</div>' +
        '<div class="specialty-pills">' +
          SPECS.map(sp => '<div class="spec-pill' + (s.specialties.includes(sp)?' selected':'') + '" onclick="toggleSpec(\'' + s.id + '\',\'' + sp + '\')">' + sp + '</div>').join('') +
        '</div>' +
        '<button class="free-text-toggle" onclick="toggleFT(\'' + s.id + '\')">' + (s.freeText ? '✎ Editar descrição' : '+ Descrição livre') + '</button>' +
        '<textarea class="free-text-area' + (s.freeText?' visible':'') + '" id="ft-' + s.id + '" placeholder="ex: Ela tem o mesmo gosto que eu para restaurantes..." oninput="updateFT(\'' + s.id + '\',this.value)">' + s.freeText + '</textarea>' +
      '</div>' +
    '</div>';
  }).join('');
}

function toggleSource(id) {
  const body = document.getElementById('sb-'+id);
  const icon = document.getElementById('exp-'+id);
  const open = body.classList.toggle('open');
  icon.classList.toggle('open', open);
}
function updateSrcName(id, val) {
  const s = sources.find(x=>x.id===id);
  if (s) { s.name = val; const av = document.querySelector('#sc-'+id+' .source-avatar'); if(av) av.textContent = val?val[0].toUpperCase():'?'; }
}
function setTrust(id, val) {
  const s = sources.find(x=>x.id===id); if(!s) return;
  s.trust = val; renderSources();
  setTimeout(()=>{ const b=document.getElementById('sb-'+id); if(b){b.classList.add('open'); document.getElementById('exp-'+id).classList.add('open');} },10);
}
function toggleSpec(id, sp) {
  const s = sources.find(x=>x.id===id); if(!s) return;
  const i = s.specialties.indexOf(sp);
  if(i>-1) s.specialties.splice(i,1); else s.specialties.push(sp);
  renderSources();
  setTimeout(()=>{ const b=document.getElementById('sb-'+id); if(b){b.classList.add('open'); document.getElementById('exp-'+id).classList.add('open');} },10);
}
function toggleFT(id) { const ft=document.getElementById('ft-'+id); if(ft) ft.classList.toggle('visible'); }
function updateFT(id, val) { const s=sources.find(x=>x.id===id); if(s) s.freeText=val; }

// ── PAGES 3-8: ONBOARDING QUESTIONS ──────────────────────────────────────────
const QUESTIONS = [
  { id:'q1', title:'Qual é o seu ritmo ideal de viagem?', sub:'Isso define quantas experiências por dia o itinerário vai sugerir.', type:'single',
    options:[
      {val:'slow', emoji:'🌿', label:'Devagar e fundo', desc:'2–3 coisas por dia, com tempo para respirar'},
      {val:'balanced', emoji:'⚖️', label:'Equilibrado', desc:'Uma âncora por período, espaço para o inesperado'},
      {val:'packed', emoji:'⚡', label:'Aproveitar ao máximo', desc:'Quero ver tudo que dá'},
    ]},
  { id:'q2', title:'O que mais importa para você em comida?', sub:'Selecione até 2 opções.', type:'multi', max:2,
    options:[
      {val:'local', emoji:'🏠', label:'Autêntico e local', desc:'Onde os moradores comem'},
      {val:'special', emoji:'⭐', label:'Experiência especial', desc:'Omakase, chef table, difícil de reservar'},
      {val:'casual', emoji:'🍜', label:'Casual e gostoso', desc:'Excelência no simples'},
      {val:'trendy', emoji:'✨', label:'Bonito e descolado', desc:'Instagramável, conceitual'},
    ]},
  { id:'q3', title:'Como você curte a vida noturna?', sub:'Sem resposta certa — é sobre o que te dá energia.', type:'single',
    options:[
      {val:'craft', emoji:'🍸', label:'Cocktails autorais', desc:'Bar escondido, bartender criativo'},
      {val:'wine', emoji:'🍷', label:'Vinho e conversa', desc:'Wine bar intimista, boa companhia'},
      {val:'local', emoji:'🏮', label:'Raiz e autêntico', desc:'Onde os moradores vão'},
      {val:'skip', emoji:'🌙', label:'Jantar cedo e hotel', desc:'Prefiro aproveitar o dia'},
    ]},
  { id:'q4', title:'Fila de 40 min num lugar incrível. Você entra?', sub:'Calibra o peso de esforço vs recompensa.', type:'single',
    options:[
      {val:'yes', emoji:'🙋', label:'Sim, se for autêntico', desc:'Vale se o lugar for de verdade'},
      {val:'maybe', emoji:'🤔', label:'Depende do dia', desc:'Com energia, sim. Sem energia, passo'},
      {val:'no', emoji:'🚶', label:'Prefiro não arriscar', desc:'Quero chegar e sentar'},
    ]},
  { id:'q5', title:'O que você costuma comprar em viagem?', sub:'Selecione tudo que se aplica.', type:'multi', max:10,
    options:[
      {val:'beauty', emoji:'💄', label:'Beleza e skincare', desc:''},
      {val:'home', emoji:'🏠', label:'Casa e decoração', desc:''},
      {val:'local', emoji:'🛍', label:'Produtos locais', desc:''},
      {val:'food', emoji:'🍫', label:'Comida para trazer', desc:''},
      {val:'fashion', emoji:'👗', label:'Roupa e moda', desc:''},
      {val:'nothing', emoji:'✈️', label:'Não costumo comprar', desc:''},
    ]},
  { id:'q6', title:'Numa viagem especial, o que pesa mais?', sub:'A última pergunta — e a mais importante.', type:'single',
    options:[
      {val:'stories', emoji:'📖', label:'Experiências para contar', desc:'O lugar impossível, a noite inesquecível'},
      {val:'comfort', emoji:'🛁', label:'Conforto e prazer', desc:'Hotel incrível, jantar sem pressa'},
      {val:'both', emoji:'✨', label:'Os dois em equilíbrio', desc:'Uma experiência única + muito conforto'},
    ]},
];

function renderQuestion(qIdx) {
  const q = QUESTIONS[qIdx];
  document.getElementById('q-eyebrow').textContent = 'Perfil ' + (qIdx+1) + ' de ' + QUESTIONS.length;
  document.getElementById('q-title').textContent = q.title;
  document.getElementById('q-sub').textContent = q.sub;
  const hint = document.getElementById('q-hint');
  if (q.type === 'multi') { hint.style.display='block'; hint.textContent = 'Selecione até ' + q.max; }
  else { hint.style.display='none'; }

  // Step dots
  document.getElementById('sdots').innerHTML = QUESTIONS.map((_,i) =>
    '<div class="sdot' + (i<qIdx?' done':i===qIdx?' active':'') + '"></div>'
  ).join('');

  // Options
  const isGrid = q.options.length >= 4;
  const savedVals = answers[q.id] || (q.type==='multi' ? [] : null);
  document.getElementById('q-options').innerHTML =
    '<div class="options' + (isGrid?' grid2':'') + '">' +
    q.options.map(o => {
      const sel = q.type==='multi' ? (savedVals||[]).includes(o.val) : savedVals===o.val;
      return '<div class="option' + (sel?' selected':'') + '" onclick="selectOpt(this,\'' + q.id + '\',\'' + o.val + '\',' + (q.type==='multi') + ',' + (q.max||1) + ')">' +
        '<span class="opt-emoji">' + o.emoji + '</span>' +
        '<div><div class="opt-label">' + o.label + '</div>' + (o.desc?'<div class="opt-desc">' + o.desc + '</div>':'') + '</div>' +
        '</div>';
    }).join('') +
    '</div>';

  const hasAnswer = q.type==='multi' ? (savedVals||[]).length>0 : !!savedVals;
  document.getElementById('q-next').disabled = !hasAnswer;
  document.getElementById('q-next').textContent = qIdx < QUESTIONS.length-1 ? 'Próxima →' : 'Ver meu perfil →';
  document.getElementById('q-back').textContent = '← ' + (qIdx===0 ? 'Voltar' : 'Anterior');
}

function selectOpt(el, qId, val, isMulti, max) {
  const container = el.parentElement;
  if (isMulti) {
    const selected = container.querySelectorAll('.selected');
    if (el.classList.contains('selected')) {
      el.classList.remove('selected');
      answers[qId] = (answers[qId]||[]).filter(v=>v!==val);
    } else {
      if (selected.length >= max) selected[0].classList.remove('selected');
      el.classList.add('selected');
      if (!answers[qId]) answers[qId] = [];
      const prev = Array.from(container.querySelectorAll('.selected')).map(e=>e.dataset ? e.dataset.val : null).filter(Boolean);
      answers[qId] = Array.from(container.querySelectorAll('.selected')).map(e => {
        const m = e.getAttribute('onclick').match(/'([^']+)'/g);
        return m && m[2] ? m[2].replace(/'/g,'') : null;
      }).filter(Boolean);
      if (!answers[qId].includes(val)) answers[qId].push(val);
    }
    document.getElementById('q-next').disabled = (answers[qId]||[]).length === 0;
  } else {
    container.querySelectorAll('.option').forEach(o=>o.classList.remove('selected'));
    el.classList.add('selected');
    answers[qId] = val;
    document.getElementById('q-next').disabled = false;
  }
}

function qNext() {
  if (currentQ < QUESTIONS.length - 1) {
    currentQ++;
    renderQuestion(currentQ);
  } else {
    generateProfile();
  }
}

function qBack() {
  if (currentQ > 0) { currentQ--; renderQuestion(currentQ); }
  else { goTo(2); }
}

// Override goTo for page 3 to init questions
const _origGoTo = goTo;
function goTo(n) {
  _origGoTo(n);
  if (n === 3) { currentQ = 0; renderQuestion(0); }
}

// ── PROFILE GENERATION ────────────────────────────────────────────────────────
const PROFILES = {
  slow_local: {title:'A Exploradora de Bolso', sub:'Você viaja para sentir, não para coletar.'},
  slow_special: {title:'A Curadora de Experiências', sub:'Menos é mais — mas o que você escolhe é impecável.'},
  balanced_local: {title:'A Equilibrista Curiosa', sub:'Você sabe quando se aventurar e quando descansar.'},
  balanced_special: {title:'A Connoisseur Moderna', sub:'Alto gosto, ritmo consciente, noites memoráveis.'},
  packed_special: {title:'A Maximalista', sub:'Quer tudo — e sabe escolher o melhor de tudo.'},
};
const TAG_MAP = {
  slow:'🌿 Ritmo tranquilo', balanced:'⚖️ Ritmo equilibrado', packed:'⚡ Ritmo intenso',
  local:'🏠 Autenticidade', special:'⭐ Experiências especiais', casual:'🍜 Casual e gostoso', trendy:'✨ Descolado',
  craft:'🍸 Cocktails autorais', wine:'🍷 Vinho e conversa',
  yes:'🙋 Aceita fila (se valer)', maybe:'🤔 Fila com critério', no:'🚶 Sem filas',
  stories:'📖 Experiências únicas', comfort:'🛁 Conforto em primeiro', both:'✨ Experiência + conforto',
};

function generateProfile() {
  const q1 = answers.q1 || 'balanced';
  const q2 = Array.isArray(answers.q2) ? answers.q2[0] : (answers.q2||'local');
  const q3 = answers.q3 || 'craft';
  const q4 = answers.q4 || 'maybe';
  const q5 = answers.q5 || [];
  const q6 = answers.q6 || 'both';

  const key = q1 + '_' + q2;
  const profile = PROFILES[key] || {title:'A Viajante com Estilo Próprio', sub:'Seu perfil é único — assim como você.'};

  const tags = [TAG_MAP[q1], TAG_MAP[q2], TAG_MAP[q3], TAG_MAP[q4], TAG_MAP[q6]].filter(Boolean);
  const rules = [];
  if (q1==='slow') rules.push('Máximo 2–3 experiências por dia. Espaço para o inesperado.');
  if (q1==='balanced') rules.push('1 âncora por período. Flexibilidade no resto.');
  if (q2==='local') rules.push('Lugares locais > turísticos. Autenticidade > hype.');
  if (q2==='special') rules.push('1 experiência especial por dia. Qualidade > quantidade.');
  if (q3==='craft') rules.push('Bares com intenção. Bartender que sabe o que faz.');
  if (q3==='local') rules.push('Noite raiz > balada turística.');
  if (q4==='yes') rules.push('Fila vale se o lugar for autêntico — não se for viral.');
  if (q4==='no') rules.push('Sem filas. Sempre ter o plano B.');
  if (q6==='comfort') rules.push('Conforto > checklist. Prazer > performance.');
  if (q6==='both') rules.push('Uma experiência única por dia. Conforto no resto.');
  if ((q5||[]).includes('beauty')) rules.push('Incluir farmácias e beauty stores na rota.');

  // Sources rules
  const trustedSame = sources.filter(s=>s.trust==='same'&&s.name).map(s=>s.name);
  const experts = sources.filter(s=>s.trust==='expert'&&s.name).map(s=>s.name);
  if (trustedSame.length) rules.push('Dicas de ' + trustedSame.join(', ') + ' têm peso máximo — mesmo gosto.');
  if (experts.length) rules.push('Dicas de ' + experts.join(', ') + ' têm peso alto — expert no destino.');

  document.getElementById('res-dest').textContent = destination.toUpperCase();
  document.getElementById('res-title').textContent = profile.title;
  document.getElementById('res-sub').textContent = profile.sub;
  document.getElementById('res-tags').innerHTML = tags.map(t=>'<span class="profile-tag">'+t+'</span>').join('');
  document.getElementById('res-rules').innerHTML = rules.map(r=>'<li><span class="rule-icon">→</span> '+r+'</li>').join('');

  // Save
  localStorage.setItem('triplens_profile', JSON.stringify({destination, answers, sources, profile, tags, rules}));

  goTo(9);
}

// Init
updateNav(0);
</script>
</body>
